APP_NAME=MainApi
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

DB_CONNECTION=mysql_main
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=main_api
DB_USERNAME=app
DB_PASSWORD=secret

SESSION_DRIVER=file
SESSION_LIFETIME=120

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
CACHE_STORE=file

MAIL_MAILER=log

# Service-to-service link to wiki-service
WIKI_SERVICE_URL=http://localhost:8001
WIKI_SERVICE_SECRET=change-me-must-match-wiki-service

# CORS — Angular dev server
FRONTEND_URL=http://localhost:4200
